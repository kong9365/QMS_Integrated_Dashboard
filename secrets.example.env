# ============================================================
# QMS 통합 대시보드 - 환경 변수 템플릿 (예시)
# ============================================================
# 사용법: 이 파일을 .env 로 복사한 뒤 실제 값으로 채우세요.
#   cp secrets.example.env .env   (Windows: copy secrets.example.env .env)
# .env 는 .gitignore 에 의해 git 추적에서 제외됩니다. 실제 비밀값을 커밋하지 마세요.
# 모든 시크릿/계정정보는 코드가 아니라 이 .env 에서만 읽습니다.

# --- QMS API (필수) ---
QMS_API_BASE_URL=https://qms.example.com
QMS_CLIENT_NAME=your-client-name
QMS_CLIENT_SECRET=your-client-secret
QMS_REALM_NAME=your-realm
QMS_LOGIN_USERNAME=your-username
QMS_LOGIN_PASSWORD=your-password

# --- QMS Proxy (qms_proxy_server.py) ---
QMS_PROXY_KEY=change-me-to-long-random-string
QMS_PROXY_ALLOW_INSECURE=
QMS_PROXY_HOST=0.0.0.0
QMS_PROXY_PORT=8787
QMS_PROXY_LIST_TTL=60
QMS_PROXY_DETAIL_TTL=300
QMS_PROXY_LOG_LEVEL=INFO

# --- MISO 연동 (qms_push_to_miso.py) ---
MISO_API_KEY=your-miso-api-key
MISO_API_BASE=https://console.miso.gs
MISO_PUSH_USER=qms-push-bot
MISO_PUSH_STATE_PATH=
MISO_PUSH_DRY_RUN=
MISO_PUSH_LOG_LEVEL=INFO
QMS_PUSH_LOG_LEVEL=INFO

# --- Slack / Email Alert (qms_alert.py) ---
QMS_SLACK_WEBHOOK=
QMS_SMTP_HOST=
QMS_SMTP_PORT=587
QMS_SMTP_USER=
QMS_SMTP_PASS=
QMS_ALERT_TO=

# --- 기타 도구 (선택: 스냅샷/스모크테스트) ---
QMS_SNAPSHOT_DIR=
QMS_PROXY_BASE=http://localhost:8787
QMS_PROXY_TIMEOUT=30
